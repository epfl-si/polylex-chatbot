# corpus (CORPUS_NAME automatically generated)

PLAYWRIGHT_BROWSERS_PATH="/srv/rag/ms-playwright"
CORPUS_NAME=''

# chunking

CHUNK_SIZE_NB_CHARS=2000
CHUNK_OVERLAP_NB_CHARS=0

# monitoring

LANGFUSE_SECRET_KEY="{{ secrets.langfuse.secret_key }}"
LANGFUSE_PUBLIC_KEY="{{ secrets.langfuse.public_key }}"
LANGFUSE_BASE_URL="http://localhost:3000"

# database (AVG_LEN_LANG + DB_COLLECTION_NAME automatically generated)

QDRANT_URL="http://localhost:6333"
AVG_LEN_FR=''
AVG_LEN_EN=''
DB_COLLECTION_NAME=''

# RCP

MODELS_BASE_URL="https://inference.rcp.epfl.ch/v1"

MODEL_EMBEDDINGS_NAME="Qwen/Qwen3-Embedding-8B"
MODEL_EMBEDDINGS_API_KEY="{{ secrets.rcp.embedding.qwen }}"
MODEL_EMBEDDINGS_DIM_VECTOR="4096"

MODEL_RERANKER_NAME="BAAI/bge-reranker-v2-m3"
MODEL_RERANKER_API_KEY="{{ secrets.rcp.reranker.bge }}"

MODEL_LLM_NAME="mistralai/Mistral-Small-3.2-24B-Instruct-2506"
MODEL_LLM_API_KEY="{{ secrets.rcp.llm.mistral }}"
NB_MAX_TOKENS_IN_LLM_CONTEXT=128000
NB_TOKENS_TO_KEEP_AVAILABLE=5000

MODEL_LLM_JUDGE_NAME="mistralai/Mistral-Small-3.2-24B-Instruct-2506"
MODEL_LLM_JUDGE_API_KEY="{{ secrets.rcp.judge.mistral }}"

MODEL_EMBEDDINGS_JUDGE_NAME="Qwen/Qwen3-Embedding-8B"
MODEL_EMBEDDINGS_JUDGE_API_KEY="{{ secrets.rcp.embedding.qwen }}"

# Hugging Face

MODEL_SPARSE_NAME="Qdrant/bm25"

# LLM

PROMPT_TEMPLATE_FR="Réponds à la question en utilisant uniquement le contexte fourni.\n\nContexte:\n{context_text}\n\nQuestion:\n{query}\n\nRéponse:"
PROMPT_TEMPLATE_EN="Answer the question using only the provided context.\n\nContext:\n{context_text}\n\nQuestion:\n{query}\n\nAnswer:"
